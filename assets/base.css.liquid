/* ============================================
   UMINO DAWN THEME - Base Styles
   Mobile-first responsive design system
   ============================================ */

/* === Reset === */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  -webkit-text-size-adjust: 100%;
  font-size: var(--font-size-base, 16px);
}

body {
  font-family: var(--font-body-family);
  font-size: 1rem;
  line-height: 1.5;
  color: var(--color-text);
  background-color: var(--color-background, #FFFFFF);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
  width: 100%;
}

img, picture, video, canvas, svg {
  display: block;
  max-width: 100%;
}

input, button, textarea, select {
  font: inherit;
}

button {
  cursor: pointer;
  background: none;
  border: none;
}

a {
  text-decoration: none;
  color: inherit;
}

ul, ol {
  list-style: none;
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading-family);
  font-weight: 500;
  overflow-wrap: break-word;
  line-height: 1;
}

/* === CSS Custom Properties === */
:root {
  /* Colors */
  --color-primary: {{ settings.color_primary }};
  --color-secondary: {{ settings.color_secondary }};
  --color-background: {{ settings.color_background }};
  --color-text: #222222;
  --color-text-muted: {{ settings.color_secondary }};
  --color-accent: {{ settings.color_accent }};
  --color-border: {{ settings.color_border }};
  --color-badge-sale: {{ settings.color_badge_sale }};
  --color-badge-preorder: {{ settings.color_badge_preorder }};
  --color-badge-soldout: {{ settings.color_badge_soldout }};
  --color-white: #FFFFFF;
  --color-dark: #111111;
  --color-gray-bg: #F5F5F5;
  --color-fc-bg: #ECEDEF;

  /* Typography */
  --font-heading-family: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
  --font-heading-style: {{ settings.font_heading.style }};
  --font-heading-weight: {{ settings.font_heading.weight }};
  --font-body-family: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
  --font-body-style: {{ settings.font_body.style }};
  --font-body-weight: {{ settings.font_body.weight }};
  --font-size-base: {{ settings.font_size_base }}px;

  /* Layout */
  --container-width: {{ settings.container_width }}px;
  --container-padding: {{ settings.container_padding }}px;

  /* Transitions */
  --transition-fast: 0.3s ease;
  --transition-standard: 0.3s cubic-bezier(0.4, 0, 0.2, 1);

  /* Border radius */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 10px;
  --radius-pill: 30px;
  --radius-full: 50%;

  /* Z-index layers */
  --z-header: 100;
  --z-mobile-nav: 90;
  --z-overlay: 80;
  --z-modal: 1000;
  --z-drawer: 999;
}

/* === Container === */
.container {
  max-width: var(--container-width);
  margin: 0 auto;
  padding: 0 20px;
}

@media (min-width: 768px) {
  .container {
    padding: 0 30px;
  }
}

@media (min-width: 1024px) {
  .container {
    padding: 0 var(--container-padding);
  }
}

@media (min-width: 1470px) {
  .container {
    padding: 0;
  }
}

.rounded-pill {
  border-radius: 100px;
}

/* === Visibility Utilities === */
.hidden { display: none !important; }
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  border: 0;
}

.desktop-only { display: none; }
.mobile-only { display: block; }

@media (min-width: 768px) {
  .desktop-only { display: block; }
  .mobile-only { display: none !important; }
}

/* === Button Components === */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-body-family);
  font-weight: 500;
  font-size: 15px;
  text-transform: capitalize;
  border-radius: var(--radius-pill);
  border: none;
  cursor: pointer;
  transition: all var(--transition-fast);
  text-decoration: none;
  line-height: 1;
  white-space: nowrap;
}

.btn-dark {
  background-color: var(--color-primary);
  color: var(--color-white);
}

.btn-dark:hover {
  background-color: #333333;
}

.btn-light {
  background-color: var(--color-white);
  color: var(--color-primary);
}

.btn-light:hover {
  background-color: var(--color-primary);
  color: var(--color-white);
}

/* === Badge Components === */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6px 11px;
  border-radius: var(--radius-pill);
  font-family: var(--font-body-family);
  font-weight: 400;
  font-size: 13px;
  line-height: 1;
  color: var(--color-white);
  z-index: 2;
  border: none;
}

.badge--sale {
  padding-right: 12px;
}

.badge--preorder {
  background-color: var(--color-badge-preorder);
}

.badge--soldout {
  background-color: var(--color-badge-soldout);
}

/* === Section Typography === */
.section-title {
  color: var(--color-dark);
  font-family: var(--font-heading-family);
  font-weight: 400;
  font-size: 36px;
  line-height: 1;
  text-align: center;
  margin-bottom: 15px;
}

.section-subtitle {
  color: var(--color-text-muted);
  font-family: var(--font-body-family);
  font-weight: 400;
  font-size: 16px;
  line-height: 1.5;
  text-align: center;
  margin-bottom: 20px;
}

@media (min-width: 768px) {
  .section-title {
    font-size: 45px;
    margin-bottom: 25px;
  }

  .section-subtitle {
    line-height: 1;
    margin-bottom: 40px;
  }
}

/* === Product Card Base === */
.product-card {
  position: relative;
  text-align: left;
  overflow: hidden;
  display: block;
}

.product-image-wrap {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  /* margin-bottom: 16px; */
  aspect-ratio: 3 / 4;
}

.product-image-wrap > img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-fast);
}

.product-card:hover .product-image-wrap > img {
  transform: scale(1.05);
}

.product-title {
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 8px;
  display: block;
  color: var(--color-text);
}

.product-description {
  font-size: 14px;
  color: var(--color-text-muted);
  margin-bottom: 8px;
}

.product-rating {
  font-size: 10px;
  color: var(--color-dark);
  margin-bottom: 8px;
  display: flex;
  gap: 1px;
}

.product-rating svg {
  width: 10px;
  height: 10px;
}

.product-price {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
}

.price-sale {
  color: var(--color-accent);
  font-weight: 500;
  font-size: 16px;
}

.price-original {
  text-decoration: line-through;
  color: #595959;
  font-weight: 500;
  font-size: 16px;
}

/* === Color Swatches === */
.product-colors {
  display: flex;
  gap: 5px;
  height: 25px;
  width: 85px;
  align-items: center;
}

.color-swatch {
  width: 25px;
  height: 25px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 1px solid #DDDDDD;
  background: #FFFFFF;
  cursor: pointer;
  transition: transform 0.2s;
  margin: 0;
  box-sizing: border-box;
}

.color-swatch-inner {
  width: 19px;
  height: 19px;
  border-radius: 50%;
  background-color: var(--swatch-color, transparent);
  display: block;
}

.color-swatch.active {
  border-color: #111111;
}


/* === Product Action Icons === */
.product-action-icons {
  position: absolute;
  top: 15px;
  right: 15px;
  display: flex;
  flex-direction: column;
  gap: 5px;
  z-index: 2;
}

.action-icon-btn {
  width: 40px;
  height: 40px;
  background: var(--color-white);
  border-radius: 100px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 5px 30px rgba(0, 0, 0, 0.05);
  color: var(--color-dark);
  font-size: 16px;
  border: none;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.action-icon-btn img {
  width: 14px;
  height: 14px;
  object-fit: contain;
}

.action-icon-btn:hover {
  background: var(--color-dark);
}

.action-icon-btn:hover img {
  filter: brightness(0) invert(1);
}

/* Desktop: hide action icons, show on hover */
@media (min-width: 768px) {
  .product-action-icons {
    opacity: 0;
    transform: translateX(150%);
    transition: all var(--transition-fast);
  }

  .product-card:hover .product-action-icons {
    opacity: 1;
    transform: translateX(0);
  }

  .product-description {
    display: none;
  }
}

/* === Add to Cart Button === */
.btn-add-cart {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  background-color: var(--color-white);
  color: var(--color-primary);
  border: none;
  padding: 10px 0;
  border-radius: var(--radius-sm);
  font-weight: 600;
  font-size: 14px;
  cursor: pointer;
  transition: all var(--transition-fast);
}

/* Mobile: hide add to cart, show sale bar */
.btn-add-cart {
  display: none;
}

@media (min-width: 768px) {
  .btn-add-cart {
    display: block;
    opacity: 0;
    visibility: hidden;
  }

  .product-card:hover .btn-add-cart {
    opacity: 1;
    visibility: visible;
    bottom: 20px;
  }

  .btn-add-cart:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }
}

/* === Sale Marquee Bar (Mobile) === */
.product-sale-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-dark);
  color: var(--color-white);
  display: flex;
  align-items: center;
  padding: 10px 0;
  font-family: var(--font-body-family);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.5px;
  z-index: 2;
  overflow: hidden;
  white-space: nowrap;
}

@media (min-width: 768px) {
  .product-sale-bar {
    display: none;
  }
}

.sale-marquee {
  display: flex;
  width: max-content;
  height: 22px;
  animation: marquee 5s linear infinite;
  will-change: transform;
}

.sale-marquee span {
  padding-right: 15px;
  display: flex;
  align-items: center;
  gap: 10px;
}

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* === Badge Positioning === */
.badge--discount {
  position: absolute;
  top: 15px;
  left: 15px;
  width: 50px;
  height: 25px;
  z-index: 2;
}

.badge--preorder-pos {
  position: absolute;
  top: 43px;
  left: 15px;
  width: 75px;
  height: 25px;
  z-index: 2;
}

.badge--soldout-pos {
  position: absolute;
  top: 15px;
  left: 15px;
  width: 70px;
  height: 25px;
  z-index: 2;
}

/* Mobile badges container */
.mobile-badges {
  display: block;
}

.desktop-badge {
  display: none;
}

@media (min-width: 768px) {
  .mobile-badges {
    display: none;
  }

  .desktop-badge {
    display: block;
  }
}

/* === Swiper Overrides === */
.swiper-button-prev,
.swiper-button-next {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-full);
  background: var(--color-white);
  border: 1px solid var(--color-border);
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
  color: #333;
  transition: all var(--transition-fast);
}

.swiper-button-prev::after,
.swiper-button-next::after {
  font-size: 14px;
  font-weight: 700;
}

.swiper-button-prev:hover,
.swiper-button-next:hover {
  background: var(--color-dark);
  color: var(--color-white);
  border-color: var(--color-dark);
}

.swiper-pagination-bullet {
  width: 8px;
  height: 8px;
  background: rgba(0, 0, 0, 0.3);
  opacity: 1;
  position: relative;
}

.swiper-pagination-bullet::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 44px;
  height: 44px;
}

.swiper-pagination-bullet-active {
  background: var(--color-dark);
}

