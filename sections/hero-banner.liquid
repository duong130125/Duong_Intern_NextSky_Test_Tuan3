{{ 'section-hero.css' | asset_url | stylesheet_tag }}

<section
  class="hero-slider-fw relative w-full h-810 sm:h-550 xs:h-550 overflow-hidden swiper"
  id="HeroSlider-{{ section.id }}"
>
  <div class="hero-slides-wrapper swiper-wrapper relative w-full h-full">
    {%- for block in section.blocks -%}
      <div
        class="hero-slide swiper-slide absolute top-0 left-0 w-full h-full flex items-center"
        {{ block.shopify_attributes }}
      >
        <div class="hero-image-wrap absolute top-0 right-0 w-full md:w-[60%] h-full z-0 overflow-hidden">
          {%- if block.settings.image != blank -%}
            {%- liquid
              assign loading_strategy = 'lazy'
              if forloop.first
                assign loading_strategy = 'eager'
              endif

              assign priority_strategy = 'auto'
              if forloop.first
                assign priority_strategy = 'high'
              endif
            -%}

            {{
              block.settings.image
              | image_url: width: 2000
              | image_tag:
                class: 'w-full h-full object-cover md:object-left',
                widths: '750, 1100, 1500, 2000',
                loading: loading_strategy,
                fetchpriority: priority_strategy,
                alt: block.settings.title
            }}
          {%- else -%}
            {%- assign image_index = forloop.index -%}
            {%- if image_index == 2 -%}
              {%- assign image_index = 3 -%}
            {%- elsif image_index == 3 -%}
              {%- assign image_index = 2 -%}
            {%- endif -%}
            {%- capture default_banner -%}banner-{{ image_index | at_most: 6 }}.webp{%- endcapture -%}
            <img
              src="{{ default_banner | asset_url }}"
              alt="{{ block.settings.title }}"
              class="w-full h-full object-cover md:object-left"
              width="2000"
              height="1000"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
            >
          {%- endif -%}
        </div>

        <div class="container hero-container w-full max-w-1410 mx-auto relative z-10 px-20 h-full">
          <div class="hero-content text-center flex flex-col items-center">
            <h1 class="hero-title mb-20 animate-fade-up-delay font-medium">
              {{ block.settings.title | newline_to_br }}
            </h1>
            <p class="hero-subtitle mb-35 animate-fade-up-delay-2">
              {{ block.settings.subtitle }}
            </p>
            {%- if block.settings.button_label != blank -%}
              <a
                href="{{ block.settings.button_link }}"
                class="btn btn-dark btn-explore w-200 h-55 flex items-center justify-center rounded-pill uppercase font-semibold text-xs mt-50 animate-fade-up-delay-2"
              >
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.show_arrows -%}
    <button
      class="hero-arrow hero-prev swiper-button-prev absolute rounded-full flex justify-center items-center cursor-pointer transition-all z-10 sm:hidden"
      aria-label="Previous Slide"
    >
      <img
        src="{{ 'left-arrow.svg' | asset_url }}"
        alt="Prev"
        width="7"
        height="11"
        class="hero-arrow-img"
      >
    </button>
    <button
      class="hero-arrow hero-next swiper-button-next absolute rounded-full flex justify-center items-center cursor-pointer transition-all z-10 sm:hidden"
      aria-label="Next Slide"
    >
      <img
        src="{{ 'right-arrow.svg' | asset_url }}"
        alt="Next"
        width="7"
        height="11"
        class="hero-arrow-img"
      >
    </button>
  {%- endif -%}

  {%- if section.settings.show_dots -%}
    <div
      class="hero-dots swiper-pagination absolute bottom-30 sm:bottom-25 left-50p translate-x--50p flex gap-10 z-10"
    ></div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero Banner",
  "max_blocks": 5,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image"
        },
        {
          "type": "text",
          "id": "pre_title",
          "label": "Pre-title",
          "default": "Stylish"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Title",
          "default": "Top Trending"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "So soft you don't want to take it off."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Explore Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
